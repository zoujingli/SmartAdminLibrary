{
  "name": "zoujingli/smart_admin_library",
  "description": "SmartAdmin base library for Hyperf applications.",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "doctrine/dbal": "^4.3",
    "ext-zip": "*",
    "hyperf/cache": "^3.2",
    "hyperf/command": "^3.2",
    "hyperf/config": "^3.2",
    "hyperf/database": "^3.2",
    "hyperf/db-connection": "^3.2",
    "hyperf/di": "^3.2",
    "hyperf/framework": "^3.2",
    "hyperf/http-server": "^3.2",
    "hyperf/logger": "^3.2",
    "hyperf/redis": "^3.2",
    "hyperf/support": "^3.2",
    "hyperf/validation": "^3.2",
    "hyperf/websocket-server": "^3.2",
    "lcobucci/jwt": "^5.6",
    "zoujingli/ip2region": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Library\\": "./"
    },
    "files": [
      "./common.php"
    ]
  },
  "extra": {
    "hyperf": {
      "config": "Library\\Provider"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5",
    "symfony/var-dumper": "^8.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse . tests --level=0 --memory-limit=1G"
  }
}
